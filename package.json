{
  "name": "litert-gemma-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --bun rspack serve",
    "build": "bun --bun tsc -b && bun --bun rspack build",
    "preview": "bun scripts/preview.ts",
    "smoke": "bun scripts/browser-smoke.mjs",
    "smoke:model": "bun scripts/browser-smoke.mjs --require-model",
    "smoke:executable": "bun scripts/executable-smoke.mjs",
    "e2e:generate": "bun scripts/e2e-generate.mjs",
    "build:sidecar": "bun scripts/build-native-runner.mjs",
    "prepare:wasm": "bun scripts/sync-wasm.mjs",
    "postinstall": "bun scripts/sync-wasm.mjs",
    "check:model": "bun scripts/check-model.mjs",
    "download:model": "bun scripts/download-model.mjs",
    "test": "bun test"
  },
  "dependencies": {
    "@litert-lm/core": "0.13.1",
    "lucide-react": "0.562.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@rspack/cli": "2.0.8",
    "@rspack/core": "2.0.8",
    "@rspack/dev-server": "2.0.3",
    "@rspack/plugin-react-refresh": "2.0.2",
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@webgpu/types": "0.1.68",
    "jsdom": "27.3.0",
    "playwright": "^1.61.0",
    "react-refresh": "0.18.0",
    "typescript": "5.9.3"
  }
}
